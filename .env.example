# Supabase project credentials (safe to expose — protected by RLS)
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
# In Supabase: Project Settings -> API -> "publishable" (a.k.a. anon) key
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR-PUBLISHABLE-KEY
# Production OAuth/email confirmation redirect, e.g. https://your-app.vercel.app
VITE_AUTH_REDIRECT_URL=http://localhost:5173
